{
  "$schema": "../../node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": ".",
  "projects": {
    "core": {
      "projectType": "library",
      "root": "../core",
      "sourceRoot": "../core/src",
      "prefix": "pv",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "../core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "../core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "../core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "karmaConfig": "../core/karma.conf.cjs",
            "preserveSymlinks": true,
            "tsConfig": "../core/tsconfig.spec.json",
            "codeCoverageExclude": [
              "../core/src/public-api.ts",
              "../core/src/lib/interfaces/**/*.ts"
            ],
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "../core/src"
            ]
          }
        }
      }
    },
    "angular": {
      "projectType": "library",
      "root": ".",
      "sourceRoot": "src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "karmaConfig": "karma.conf.cjs",
            "preserveSymlinks": true,
            "tsConfig": "tsconfig.spec.json",
            "codeCoverageExclude": [
              "src/public-api.ts"
            ],
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src"
            ]
          }
        }
      }
    },
    "angular-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "sass"
        }
      },
      "root": "../../apps/angular-demo",
      "sourceRoot": "../../apps/angular-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "../../dist/angular-demo",
            "preserveSymlinks": true,
            "index": "../../apps/angular-demo/src/index.html",
            "main": "../../apps/angular-demo/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "../../apps/angular-demo/tsconfig.app.json",
            "inlineStyleLanguage": "sass",
            "assets": [
              "../../apps/angular-demo/src/assets",
              {
                "glob": "**/*",
                "input": "../../tools/platform-shell",
                "output": "/"
              }
            ],
            "styles": [
              "../../tools/platform-shell/platform-theme.css",
              "../../node_modules/bootstrap/dist/css/bootstrap.min.css",
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "../../dist/validation-rules-angular/styles/policy-validation.css",
              "../../apps/angular-demo/src/styles.sass"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "angular-demo:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "angular-demo:build:production"
            },
            "development": {
              "buildTarget": "angular-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "angular-demo:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "karmaConfig": "../../apps/angular-demo/karma.conf.cjs",
            "preserveSymlinks": true,
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "../../apps/angular-demo/tsconfig.spec.json",
            "codeCoverageExclude": [
              "../../apps/angular-demo/src/main.ts"
            ],
            "inlineStyleLanguage": "sass",
            "assets": [
              "../../apps/angular-demo/src/assets",
              {
                "glob": "**/*",
                "input": "../../tools/platform-shell",
                "output": "/"
              }
            ],
            "styles": [
              "../../tools/platform-shell/platform-theme.css",
              "../../apps/angular-demo/src/styles.sass"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "../../apps/angular-demo/src"
            ]
          }
        }
      }
    },
    "angular-ngrx-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "sass"
        }
      },
      "root": "../../apps/angular-ngrx-demo",
      "sourceRoot": "../../apps/angular-ngrx-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "../../dist/angular-ngrx-demo",
            "preserveSymlinks": true,
            "index": "../../apps/angular-ngrx-demo/src/index.html",
            "main": "../../apps/angular-ngrx-demo/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "../../apps/angular-ngrx-demo/tsconfig.app.json",
            "inlineStyleLanguage": "sass",
            "assets": [
              {
                "glob": "**/*",
                "input": "../../tools/platform-shell",
                "output": "/"
              }
            ],
            "styles": [
              "../../tools/platform-shell/platform-theme.css",
              "../../apps/angular-ngrx-demo/src/styles.sass"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "900kb",
                  "maximumError": "1.1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kb",
                  "maximumError": "12kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "angular-ngrx-demo:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "angular-ngrx-demo:build:production"
            },
            "development": {
              "buildTarget": "angular-ngrx-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "angular-ngrx-demo:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "karmaConfig": "../../apps/angular-ngrx-demo/karma.conf.cjs",
            "preserveSymlinks": true,
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "../../apps/angular-ngrx-demo/tsconfig.spec.json",
            "codeCoverageExclude": [
              "../../apps/angular-ngrx-demo/src/main.ts"
            ],
            "inlineStyleLanguage": "sass",
            "assets": [
              {
                "glob": "**/*",
                "input": "../../tools/platform-shell",
                "output": "/"
              }
            ],
            "styles": [
              "../../tools/platform-shell/platform-theme.css",
              "../../apps/angular-ngrx-demo/src/styles.sass"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "../../apps/angular-ngrx-demo/src"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "schematicCollections": [
      "@angular-eslint/schematics"
    ]
  }
}
