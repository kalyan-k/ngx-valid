{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/packages/react",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "inlineSources": true,
    "rootDir": "src",
    "types": ["react", "react-dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.spec.tsx", "src/testing/**"]
}
