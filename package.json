{
  "name": "validation-rules-workspace",
  "version": "0.0.0",
  "type": "module",
  "description": "Private monorepo for the Validation Rules engine, framework adapter, demo portal, documentation, and Angular examples.",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "ng": "cd packages/angular && ng",
    "start": "npm run demo",
    "serve": "npm run serve:demo",
    "serve:demo": "npm run build:packages && npm run ng -- serve angular-demo",
    "serve:docs": "npm run build:docs && node dist/apps/docs/server.js",
    "serve:docs:portal": "node dist/apps/docs/server.js",
    "serve:angular-demo:portal": "npm run ng -- serve angular-demo",
    "serve:react-demo:portal": "vite --config apps/react-demo/vite.config.ts",
    "demo": "npm run build:packages && npm run build:platform && node dist/apps/demo/server.js",
    "build": "npm run build:packages",
    "build:core": "npm run ng -- build core --configuration production",
    "build:angular": "npm run build:core && npm run ng -- build angular --configuration production",
    "build:react": "npm run build:core && npm run build --workspace @validation-rules/react",
    "build:packages": "npm run build:angular && npm run build:react",
    "build:lib": "npm run build:angular",
    "build:demo": "npm run build:packages && npm run ng -- build angular-demo --configuration production",
    "build:react-demo": "npm run build:react && npm run build --workspace @validation-rules/react-demo",
    "build:portal": "tsc -p apps/demo/tsconfig.json",
    "build:docs": "tsc -p apps/docs/tsconfig.json",
    "build:platform": "npm run build:portal && npm run build:docs",
    "build:demos": "npm run build:packages && npm run ng -- build angular-demo --configuration production && npm run build --workspace @validation-rules/react-demo",
    "build:all": "npm run build:platform && npm run build:demos",
    "build-core": "npm run build:core",
    "build-demo": "npm run build:demo",
    "watch": "npm run watch:lib",
    "watch:lib": "npm run build:core && npm run ng -- build angular --configuration development --watch",
    "pack:lib": "npm run build:lib && npm pack ./dist/validation-rules-angular --dry-run",
    "publish:lib": "npm run build:lib && npm publish ./dist/validation-rules-angular --access public",
    "architecture:verify": "node tools/architecture/verify-dependencies.mjs",
    "test": "npm run test:platform && npm run test:core && npm run test:angular && npm run test:react && npm run test:demo && npm run test:react-demo",
    "test:platform": "npm run build:platform && node --test dist/apps/demo/process-manager.spec.js dist/apps/docs/markdown.spec.js dist/apps/docs/search.spec.js",
    "test:core": "npm run ng -- test core --watch=false --browsers=ChromeHeadlessLocal",
    "test:angular": "npm run ng -- test angular --watch=false --browsers=ChromeHeadlessLocal",
    "test:react": "vitest run --config packages/react/vitest.config.ts && node tools/testing/normalize-vitest-report.mjs react",
    "test:demo": "npm run ng -- test angular-demo --watch=false --browsers=ChromeHeadlessLocal",
    "test:react-demo": "vitest run --config apps/react-demo/vite.config.ts && node tools/testing/normalize-vitest-report.mjs react-demo",
    "test:coverage": "npm run test:platform && npm run test:coverage:core && npm run test:coverage:angular && npm run test:coverage:react && npm run test:coverage:demo && npm run test:coverage:react-demo",
    "test:coverage:core": "npm run ng -- test core --watch=false --browsers=ChromeHeadlessLocal --code-coverage",
    "test:coverage:angular": "npm run ng -- test angular --watch=false --browsers=ChromeHeadlessLocal --code-coverage",
    "test:coverage:react": "vitest run --config packages/react/vitest.config.ts --coverage && node tools/testing/normalize-vitest-report.mjs react",
    "test:coverage:demo": "npm run ng -- test angular-demo --watch=false --browsers=ChromeHeadlessLocal --code-coverage",
    "test:coverage:react-demo": "vitest run --config apps/react-demo/vite.config.ts --coverage && node tools/testing/normalize-vitest-report.mjs react-demo",
    "test:coverage:core:ci": "npm run ng -- test core --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:coverage:angular:ci": "npm run ng -- test angular --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:coverage:react:ci": "npm run test:coverage:react",
    "test:coverage:demo:ci": "npm run ng -- test angular-demo --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:coverage:react-demo:ci": "npm run test:coverage:react-demo",
    "test:reports:core": "node tools/testing/run-project-report.mjs core",
    "test:reports:angular": "node tools/testing/run-project-report.mjs angular",
    "test:reports:react": "node tools/testing/run-project-report.mjs react",
    "test:reports:demo": "node tools/testing/run-project-report.mjs angular-demo",
    "test:reports:react-demo": "node tools/testing/run-project-report.mjs react-demo",
    "test:reports": "node tools/testing/run-all-reports.mjs",
    "test:ci": "npm run test:platform && node tools/testing/run-all-reports.mjs --ci",
    "test:all": "npm test",
    "test:watch:core": "npm run ng -- test core",
    "test:watch:angular": "npm run ng -- test angular",
    "test:watch:react": "vitest --config packages/react/vitest.config.ts",
    "test:watch:demo": "npm run ng -- test angular-demo",
    "test:watch:react-demo": "vitest --config apps/react-demo/vite.config.ts",
    "start:react-demo": "npm run serve:react-demo:portal",
    "reports:clean": "node tools/testing/clean-reports.mjs",
    "reports:index": "node tools/testing/generate-report-platform.mjs",
    "reports:verify": "node tools/testing/verify-reports.mjs",
    "reports:open": "node tools/testing/open-reports.mjs",
    "lint": "npm run ng -- lint angular",
    "lint:all": "npm run ng -- lint"
  },
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@datorama/akita": "^7.1.1",
    "@ngneat/elf": "^2.5.1",
    "@ngneat/elf-entities": "^5.0.2",
    "@ngrx/store": "^20.1.0",
    "@ngxs/store": "^20.1.0",
    "@rx-angular/cdk": "^20.1.0",
    "@rx-angular/state": "^20.1.0",
    "bootstrap": "^5.3.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "underscore": "^1.13.8",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.25",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/underscore": "^1.13.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.4.0",
    "jsdom": "^26.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mobx": "6.16.1",
    "ng-packagr": "^20.3.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "~5.8.3",
    "vite": "^6.4.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "lodash": "4.18.1",
    "glob": "^13.0.0",
    "ws": "^8.18.0",
    "rollup": "^4.34.0",
    "flatted": "^3.3.2",
    "body-parser": "^1.20.3",
    "node-forge": "^1.3.2",
    "immutable": "^4.3.8",
    "braces": "^3.0.3",
    "tar": "^7.4.0",
    "webpack-dev-middleware": "^7.4.2",
    "minimatch": "^10.2.5",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.4",
    "piscina": "^4.9.0",
    "ip": "^2.0.1",
    "uuid": "^11.1.1",
    "mobx": "6.16.1",
    "vite": "$vite",
    "esbuild": "^0.25.0",
    "http-proxy-middleware": "^3.0.7",
    "webpack-dev-server": "^5.2.5",
    "@babel/core": "^7.29.1",
    "@sigstore/core": "^3.2.1",
    "karma": {
      "minimatch": "3.1.4"
    }
  }
}
