{
  "name": "policy-validation-workspace",
  "version": "0.0.0",
  "description": "Private Angular workspace for the Policy Validation library and demo app.",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "npm run serve:demo",
    "serve": "npm run serve:demo",
    "serve:demo": "ng build core --configuration development && ng serve demo-app",
    "build": "npm run build:lib",
    "build:lib": "ng build core --configuration production",
    "build:demo": "npm run build:lib && ng build demo-app --configuration production",
    "build:all": "npm run build:lib && ng build demo-app --configuration production",
    "build-core": "npm run build:lib",
    "build-demo": "npm run build:demo",
    "watch": "npm run watch:lib",
    "watch:lib": "ng build core --configuration development --watch",
    "pack:lib": "npm run build:lib && npm pack ./dist/policy-validation --dry-run",
    "publish:lib": "npm run build:lib && npm publish ./dist/policy-validation --access public",
    "test": "npm run test:core && npm run test:demo",
    "test:core": "ng test core --watch=false --browsers=ChromeHeadless",
    "test:demo": "ng test demo-app --watch=false --browsers=ChromeHeadless",
    "test:coverage": "npm run test:coverage:core && npm run test:coverage:demo",
    "test:coverage:core": "ng test core --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:coverage:demo": "ng test demo-app --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:coverage:core:ci": "ng test core --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:coverage:demo:ci": "ng test demo-app --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "test:reports:core": "node tools/testing/run-project-report.mjs core",
    "test:reports:demo": "node tools/testing/run-project-report.mjs demo-app",
    "test:reports": "node tools/testing/run-all-reports.mjs",
    "test:ci": "node tools/testing/run-all-reports.mjs --ci",
    "test:all": "npm test",
    "test:watch:core": "ng test core",
    "test:watch:demo": "ng test demo-app",
    "reports:clean": "node tools/testing/clean-reports.mjs",
    "reports:index": "node tools/testing/generate-report-index.mjs",
    "reports:verify": "node tools/testing/verify-reports.mjs",
    "reports:open": "node tools/testing/open-reports.mjs",
    "lint": "ng lint core",
    "lint:all": "ng lint"
  },
  "license": "MIT",
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@ngrx/store": "^20.1.0",
    "bootstrap": "^5.3.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "underscore": "^1.13.8",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.25",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@types/jasmine": "~5.1.0",
    "@types/underscore": "^1.13.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.2",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "lodash": "4.18.1",
    "glob": "^13.0.0",
    "ws": "^8.18.0",
    "rollup": "^4.34.0",
    "flatted": "^3.3.2",
    "body-parser": "^1.20.3",
    "node-forge": "^1.3.2",
    "immutable": "^4.3.8",
    "braces": "^3.0.3",
    "tar": "^7.4.0",
    "webpack-dev-middleware": "^7.4.2",
    "minimatch": "^10.2.5",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.4",
    "piscina": "^4.9.0",
    "ip": "^2.0.1",
    "uuid": "^11.1.1",
    "vite": "^6.4.3",
    "esbuild": "^0.25.0",
    "http-proxy-middleware": "^3.0.7",
    "webpack-dev-server": "^5.2.5",
    "@babel/core": "^7.29.1",
    "@sigstore/core": "^3.2.1",
    "karma": {
      "minimatch": "3.1.4"
    }
  }
}
